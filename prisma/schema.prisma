generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KnowledgeType {
  EXPERIENCE
  TEMPLATE
  POSITION
  NOTE
}

enum KnowledgeSource {
  USER
  AI
  REVIEW
  PLAN
}

enum PlanPriority {
  LOW
  MEDIUM
  HIGH
}

enum CandidateStatus {
  ACTIVE
  TALENT_POOL
  ARCHIVED
}

enum CandidateAuditAction {
  CREATED
  UPDATED
  ARCHIVED
  RESTORED
  RESUME_LINKED
  RESUME_UNLINKED
}

enum ApplicationStage {
  NEW
  RESUME_SCREEN
  PHONE_SCREEN
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum ApplicationEventType {
  CREATED
  STAGE_CHANGED
  NOTE_ADDED
}

model RecruitLog {
  id             String   @id @default(uuid())
  date           DateTime @unique
  position       String?
  resumeCount    Int      @default(0)
  screenCount    Int      @default(0)
  phoneCount     Int      @default(0)
  interviewCount Int      @default(0)
  offerCount     Int      @default(0)
  entryCount     Int      @default(0)
  source         String?
  channel        String?
  roleType       String?
  priority       String?
  summary        String?
  problems       String?
  reflection     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  review DailyReview?
  plans  DailyPlan[]

  @@index([date])
}

model DailyReview {
  id            String   @id @default(uuid())
  logId         String   @unique
  summary       String
  strengths     Json
  weaknesses    Json
  suggestions   Json
  score         Int
  provider      String
  model         String
  promptFile    String
  promptVersion String
  inputHash     String
  rawOutput     Json
  parsedOutput  Json
  createdAt     DateTime @default(now())

  log       RecruitLog  @relation(fields: [logId], references: [id])
  plans     DailyPlan[]
  knowledge Knowledge[]

  @@index([createdAt])
}

model AIRequestLog {
  id           String   @id @default(uuid())
  feature      String
  model        String
  promptTokens Int?
  outputTokens Int?
  totalTokens  Int?
  latencyMs    Int?
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([feature])
  @@index([createdAt])
}

model DailyPlan {
  id               String       @id @default(uuid())
  date             DateTime
  logId            String?
  reviewId         String?
  schedule         Json
  priorityTasks    Json
  goals            Json
  risks            Json
  expectedOutcomes Json
  priority         PlanPriority
  provider         String
  model            String
  promptFile       String
  promptVersion    String
  inputHash        String
  rawOutput        Json
  parsedOutput     Json
  createdAt        DateTime     @default(now())

  log       RecruitLog?  @relation(fields: [logId], references: [id])
  review    DailyReview? @relation(fields: [reviewId], references: [id])
  knowledge Knowledge[]

  @@index([date])
  @@index([logId])
  @@index([reviewId])
}

model Knowledge {
  id             String          @id @default(uuid())
  title          String
  content        String
  type           KnowledgeType
  source         KnowledgeSource
  tags           String[]
  sourceReviewId String?
  sourcePlanId   String?
  rawOutput      Json?
  parsedOutput   Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  sourceReview DailyReview? @relation(fields: [sourceReviewId], references: [id])
  sourcePlan   DailyPlan?   @relation(fields: [sourcePlanId], references: [id])

  @@index([type])
  @@index([source])
  @@index([createdAt])
}

model UploadedSpreadsheet {
  id        String   @id @default(uuid())
  fileName  String
  fileType  String
  rowCount  Int?
  status    String
  createdAt DateTime @default(now())

  analysis SpreadsheetAnalysis?

  @@index([createdAt])
  @@index([status])
}

model SpreadsheetAnalysis {
  id          String   @id @default(uuid())
  uploadId    String   @unique
  summary     String
  insights    String
  problems    String
  suggestions String
  rawJson     Json?
  model       String
  createdAt   DateTime @default(now())

  upload UploadedSpreadsheet @relation(fields: [uploadId], references: [id])

  @@index([createdAt])
}

model JobProfile {
  id                         String    @id @default(uuid())
  workflowId                 String
  jobTitle                   String
  jd                         String
  leaderRequirements         String?
  teamBackground             String?
  hiringGoal                 String?
  notes                      String?
  jobSummary                 String
  coreResponsibilities       String[]
  requiredCompetencies       String[]
  preferredCompetencies      String[]
  potentialRisks             String[]
  hiringFocus                String[]
  interviewFocus             String[]
  missingInformation         String[]
  suggestedFollowUpQuestions String[]
  aiProvider                 String
  aiModel                    String
  promptFile                 String
  promptVersion              String
  generationTimeMs           Int?
  reviewedAt                 DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  candidateResumes         CandidateResume[]
  candidateInsights        CandidateInsight[]
  recruitTogetherWorkflows RecruitTogetherWorkflow[]
  applications             CandidateApplication[]

  @@index([workflowId])
  @@index([createdAt])
}

model CandidateResume {
  id              String   @id @default(uuid())
  workflowId      String
  jobProfileId    String
  candidateId     String?
  fileName        String
  fileType        String
  fileSize        Int
  originalFile    Bytes
  parsedText      String?
  parsingStatus   String
  parsingError    String?
  structureChunks Json
  semanticChunks  Json
  resumeVersion   String
  candidateSource String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidate  Candidate?        @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  jobProfile JobProfile        @relation(fields: [jobProfileId], references: [id])
  insight    CandidateInsight?

  @@index([workflowId])
  @@index([jobProfileId])
  @@index([candidateId])
  @@index([createdAt])
}

model Candidate {
  id               String          @id @default(uuid())
  fullName         String
  email            String?
  phone            String?
  currentCompany   String?
  currentTitle     String?
  targetRoles      String[]
  sourceChannel    String?
  owner            String?
  tags             String[]
  notes            String?
  status           CandidateStatus @default(ACTIVE)
  latestActivityAt DateTime        @default(now())
  archivedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  resumes      CandidateResume[]
  audits       CandidateAudit[]
  applications CandidateApplication[]

  @@index([fullName])
  @@index([status])
  @@index([sourceChannel])
  @@index([owner])
  @@index([latestActivityAt])
  @@index([createdAt])
}

model CandidateAudit {
  id          String               @id @default(uuid())
  candidateId String
  action      CandidateAuditAction
  actor       String
  beforeValue Json?
  afterValue  Json?
  note        String?
  createdAt   DateTime             @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@index([candidateId])
  @@index([action])
  @@index([createdAt])
}

model CandidateApplication {
  id               String           @id @default(cuid())
  candidateId      String
  jobProfileId     String
  currentStage     ApplicationStage @default(NEW)
  owner            String?
  sourceChannel    String?
  notes            String?
  latestActivityAt DateTime         @default(now())
  closedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  candidate  Candidate          @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  jobProfile JobProfile         @relation(fields: [jobProfileId], references: [id], onDelete: Restrict)
  events     ApplicationEvent[]

  @@index([candidateId])
  @@index([jobProfileId])
  @@index([currentStage])
  @@index([owner])
  @@index([latestActivityAt])
  @@index([closedAt])
}

model ApplicationEvent {
  id            String               @id @default(cuid())
  applicationId String
  eventType     ApplicationEventType
  actor         String?
  fromStage     ApplicationStage?
  toStage       ApplicationStage?
  note          String?
  createdAt     DateTime             @default(now())

  application CandidateApplication @relation(fields: [applicationId], references: [id], onDelete: Restrict)

  @@index([applicationId, createdAt])
  @@index([eventType])
}

model CandidateInsight {
  id                            String    @id @default(uuid())
  workflowId                    String
  jobProfileId                  String
  resumeId                      String    @unique
  candidateSource               String?
  notes                         String?
  summary                       Json
  insights                      Json
  strengths                     String[]
  potentialRisks                String[]
  missingInformation            String[]
  suggestedPhoneScreenQuestions String[]
  suggestedInterviewQuestions   String[]
  suggestedNextActions          String[]
  evidence                      Json
  aiProvider                    String
  aiModel                       String
  promptFile                    String
  promptVersion                 String
  generationTimeMs              Int?
  jobProfileVersion             String
  resumeVersion                 String
  reviewedAt                    DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  jobProfile               JobProfile                @relation(fields: [jobProfileId], references: [id])
  resume                   CandidateResume           @relation(fields: [resumeId], references: [id])
  recruitTogetherWorkflows RecruitTogetherWorkflow[]

  @@index([workflowId])
  @@index([jobProfileId])
  @@index([createdAt])
}

model RecruitTogetherWorkflow {
  id                   String   @id @default(uuid())
  workflowId           String
  jobProfileId         String
  candidateInsightId   String
  phonePreparation     Json
  phoneNotes           Json
  interviewPreparation Json
  interviewNotes       Json
  recruiterSummary     Json
  aiProvider           String
  aiModel              String
  promptVersions       Json
  generationTimes      Json
  humanReview          Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  jobProfile       JobProfile       @relation(fields: [jobProfileId], references: [id])
  candidateInsight CandidateInsight @relation(fields: [candidateInsightId], references: [id])

  @@index([workflowId])
  @@index([jobProfileId])
  @@index([candidateInsightId])
  @@index([createdAt])
}

model DailyRecruitingWorkspace {
  id                     String   @id @default(uuid())
  workflowId             String
  date                   DateTime
  activitySnapshot       Json
  dailySummary           Json
  recruitingInsights     Json
  tomorrowPriorities     Json
  improvementSuggestions Json
  manualNotes            String?
  aiProvider             String
  aiModel                String
  promptVersions         Json
  generationTimes        Json
  humanReview            Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([workflowId])
  @@index([date])
  @@index([createdAt])
}

model RecruiterWorkspaceNote {
  id             String   @id @default(uuid())
  date           DateTime
  content        String
  category       String?
  source         String   @default("MANUAL")
  searchableText String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
  @@index([createdAt])
}

model RecruiterWorkspaceScheduleItem {
  id          String   @id @default(uuid())
  date        DateTime
  itemType    String
  title       String
  startTime   String?
  relatedName String?
  notes       String?
  completed   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([itemType])
  @@index([createdAt])
}

model RecruitmentTask {
  id                    String    @id @default(uuid())
  sourceKey             String    @unique
  sourceType            String
  category              String
  title                 String
  priority              String
  priorityReason        String
  reason                String
  evidence              String[]
  relatedWorkflow       String?
  relatedCandidate      String?
  relatedJob            String?
  dueTime               DateTime?
  confidence            String    @default("MEDIUM")
  recommendedNextAction String
  status                String    @default("TODO")
  quickStartHref        String?
  createdBy             String    @default("AI_RECRUITER")
  reviewedByRecruiter   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  audits RecruitmentTaskAudit[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([sourceType])
  @@index([dueTime])
  @@index([createdAt])
}

model RecruitmentTaskAudit {
  id           String   @id @default(uuid())
  taskId       String
  action       String
  actor        String
  beforeStatus String?
  afterStatus  String?
  beforeValue  Json?
  afterValue   Json?
  note         String?
  createdAt    DateTime @default(now())

  task RecruitmentTask @relation(fields: [taskId], references: [id])

  @@index([taskId])
  @@index([action])
  @@index([createdAt])
}
