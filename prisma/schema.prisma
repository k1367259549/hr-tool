generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KnowledgeType {
  EXPERIENCE
  TEMPLATE
  POSITION
  NOTE
}

enum KnowledgeSource {
  USER
  AI
  REVIEW
  PLAN
}

enum PlanPriority {
  LOW
  MEDIUM
  HIGH
}

enum CandidateStatus {
  ACTIVE
  TALENT_POOL
  ARCHIVED
}

enum CandidateAuditAction {
  CREATED
  UPDATED
  ARCHIVED
  RESTORED
  RESUME_LINKED
  RESUME_UNLINKED
}

enum ApplicationStage {
  NEW
  RESUME_SCREEN
  PHONE_SCREEN
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum ApplicationEventType {
  CREATED
  STAGE_CHANGED
  NOTE_ADDED
}

enum EvaluationTemplateStatus {
  ACTIVE
  ARCHIVED
}

enum EvaluationTemplateVersionStatus {
  DRAFT
  PUBLISHED
}

enum ResumeEvaluationStatus {
  DRAFT
  REVIEWED
}

enum ResumeEvaluationEventType {
  CREATED
  UPDATED
  REVIEWED
  REOPENED
}

enum ResumeEvaluationRunType {
  MOCK
  RULE_BASED
  AI
}

enum ResumeEvaluationRunStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum ResumeReviewerDecision {
  PASS
  REJECT
  HOLD
  NEEDS_MORE_INFO
}

enum ResumeParsingStatus {
  PARSED
  FAILED
}

model RecruitLog {
  id             String   @id @default(uuid())
  date           DateTime @unique
  position       String?
  resumeCount    Int      @default(0)
  screenCount    Int      @default(0)
  phoneCount     Int      @default(0)
  interviewCount Int      @default(0)
  offerCount     Int      @default(0)
  entryCount     Int      @default(0)
  source         String?
  channel        String?
  roleType       String?
  priority       String?
  summary        String?
  problems       String?
  reflection     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  review DailyReview?
  plans  DailyPlan[]

  @@index([date])
}

model DailyReview {
  id            String   @id @default(uuid())
  logId         String   @unique
  summary       String
  strengths     Json
  weaknesses    Json
  suggestions   Json
  score         Int
  provider      String
  model         String
  promptFile    String
  promptVersion String
  inputHash     String
  rawOutput     Json
  parsedOutput  Json
  createdAt     DateTime @default(now())

  log       RecruitLog  @relation(fields: [logId], references: [id])
  plans     DailyPlan[]
  knowledge Knowledge[]

  @@index([createdAt])
}

model AIRequestLog {
  id           String   @id @default(uuid())
  feature      String
  model        String
  promptTokens Int?
  outputTokens Int?
  totalTokens  Int?
  latencyMs    Int?
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([feature])
  @@index([createdAt])
}

model DailyPlan {
  id               String       @id @default(uuid())
  date             DateTime
  logId            String?
  reviewId         String?
  schedule         Json
  priorityTasks    Json
  goals            Json
  risks            Json
  expectedOutcomes Json
  priority         PlanPriority
  provider         String
  model            String
  promptFile       String
  promptVersion    String
  inputHash        String
  rawOutput        Json
  parsedOutput     Json
  createdAt        DateTime     @default(now())

  log       RecruitLog?  @relation(fields: [logId], references: [id])
  review    DailyReview? @relation(fields: [reviewId], references: [id])
  knowledge Knowledge[]

  @@index([date])
  @@index([logId])
  @@index([reviewId])
}

model Knowledge {
  id             String          @id @default(uuid())
  title          String
  content        String
  type           KnowledgeType
  source         KnowledgeSource
  tags           String[]
  sourceReviewId String?
  sourcePlanId   String?
  rawOutput      Json?
  parsedOutput   Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  sourceReview DailyReview? @relation(fields: [sourceReviewId], references: [id])
  sourcePlan   DailyPlan?   @relation(fields: [sourcePlanId], references: [id])

  @@index([type])
  @@index([source])
  @@index([createdAt])
}

model UploadedSpreadsheet {
  id        String   @id @default(uuid())
  fileName  String
  fileType  String
  rowCount  Int?
  status    String
  createdAt DateTime @default(now())

  analysis SpreadsheetAnalysis?

  @@index([createdAt])
  @@index([status])
}

model SpreadsheetAnalysis {
  id          String   @id @default(uuid())
  uploadId    String   @unique
  summary     String
  insights    String
  problems    String
  suggestions String
  rawJson     Json?
  model       String
  createdAt   DateTime @default(now())

  upload UploadedSpreadsheet @relation(fields: [uploadId], references: [id])

  @@index([createdAt])
}

model JobProfile {
  id                         String    @id @default(uuid())
  workflowId                 String
  jobTitle                   String
  jd                         String
  leaderRequirements         String?
  teamBackground             String?
  hiringGoal                 String?
  notes                      String?
  jobSummary                 String
  coreResponsibilities       String[]
  requiredCompetencies       String[]
  preferredCompetencies      String[]
  potentialRisks             String[]
  hiringFocus                String[]
  interviewFocus             String[]
  missingInformation         String[]
  suggestedFollowUpQuestions String[]
  aiProvider                 String
  aiModel                    String
  promptFile                 String
  promptVersion              String
  generationTimeMs           Int?
  reviewedAt                 DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  candidateResumes              CandidateResume[]
  candidateInsights             CandidateInsight[]
  recruitTogetherWorkflows      RecruitTogetherWorkflow[]
  applications                  CandidateApplication[]
  evaluationTemplateAssignments JobProfileEvaluationAssignment[]
  resumeEvaluations             ResumeEvaluationResult[]
  evaluationRuns                ResumeEvaluationRun[]

  @@index([workflowId])
  @@index([createdAt])
}

model CandidateResume {
  id              String   @id @default(uuid())
  workflowId      String
  jobProfileId    String?
  candidateId     String?
  fileName        String
  fileType        String
  fileSize        Int
  originalFile    Bytes
  parsedText      String?
  parsingStatus   String
  parsingError    String?
  structureChunks Json
  semanticChunks  Json
  resumeVersion   String
  candidateSource String?
  notes           String?
  intakeSource    String?
  contentHash     String?
  language        String?
  parserVersion   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidate         Candidate?               @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  jobProfile        JobProfile?              @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  insight           CandidateInsight?
  revisions         ResumeRevision[]
  resumeEvaluations ResumeEvaluationResult[]
  evaluationRuns    ResumeEvaluationRun[]

  @@index([workflowId])
  @@index([jobProfileId])
  @@index([candidateId])
  @@index([contentHash])
  @@index([parsingStatus])
  @@index([fileType])
  @@index([intakeSource])
  @@index([createdAt])
}

model ResumeRevision {
  id             String              @id @default(cuid())
  resumeId       String
  revisionNumber Int
  contentHash    String?
  source         String?
  sourceFileName String?
  parserVersion  String?
  parseStatus    ResumeParsingStatus
  createdAt      DateTime            @default(now())

  resume            CandidateResume          @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  parsedSnapshot    ParsedSnapshot?
  resumeEvaluations ResumeEvaluationResult[] @relation("EvaluationResumeRevision")
  evaluationRuns    ResumeEvaluationRun[]

  @@unique([resumeId, revisionNumber])
  @@index([resumeId])
  @@index([contentHash])
  @@index([createdAt])
}

model ParsedSnapshot {
  id             String   @id @default(cuid())
  revisionId     String   @unique
  parsedText     String?
  structuredData Json?
  chunkCount     Int      @default(0)
  createdAt      DateTime @default(now())

  revision          ResumeRevision           @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  resumeEvaluations ResumeEvaluationResult[] @relation("EvaluationParsedSnapshot")
  evaluationRuns    ResumeEvaluationRun[]

  @@index([createdAt])
}

model Candidate {
  id               String          @id @default(uuid())
  fullName         String
  email            String?
  phone            String?
  currentCompany   String?
  currentTitle     String?
  targetRoles      String[]
  sourceChannel    String?
  owner            String?
  tags             String[]
  notes            String?
  status           CandidateStatus @default(ACTIVE)
  latestActivityAt DateTime        @default(now())
  archivedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  resumes      CandidateResume[]
  audits       CandidateAudit[]
  applications CandidateApplication[]

  @@index([fullName])
  @@index([status])
  @@index([sourceChannel])
  @@index([owner])
  @@index([latestActivityAt])
  @@index([createdAt])
}

model CandidateAudit {
  id          String               @id @default(uuid())
  candidateId String
  action      CandidateAuditAction
  actor       String
  beforeValue Json?
  afterValue  Json?
  note        String?
  createdAt   DateTime             @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@index([candidateId])
  @@index([action])
  @@index([createdAt])
}

model CandidateApplication {
  id               String           @id @default(cuid())
  candidateId      String
  jobProfileId     String
  currentStage     ApplicationStage @default(NEW)
  owner            String?
  sourceChannel    String?
  notes            String?
  latestActivityAt DateTime         @default(now())
  closedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  candidate  Candidate          @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  jobProfile JobProfile         @relation(fields: [jobProfileId], references: [id], onDelete: Restrict)
  events     ApplicationEvent[]

  @@index([candidateId])
  @@index([jobProfileId])
  @@index([currentStage])
  @@index([owner])
  @@index([latestActivityAt])
  @@index([closedAt])
}

model ApplicationEvent {
  id            String               @id @default(cuid())
  applicationId String
  eventType     ApplicationEventType
  actor         String?
  fromStage     ApplicationStage?
  toStage       ApplicationStage?
  note          String?
  createdAt     DateTime             @default(now())

  application CandidateApplication @relation(fields: [applicationId], references: [id], onDelete: Restrict)

  @@index([applicationId, createdAt])
  @@index([eventType])
}

model EvaluationTemplate {
  id                  String                   @id @default(cuid())
  name                String
  description         String?
  status              EvaluationTemplateStatus @default(ACTIVE)
  latestVersionNumber Int                      @default(0)
  archivedAt          DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  versions EvaluationTemplateVersion[]

  @@index([name])
  @@index([status])
  @@index([createdAt])
}

model EvaluationTemplateVersion {
  id            String                          @id @default(cuid())
  templateId    String
  versionNumber Int
  status        EvaluationTemplateVersionStatus @default(DRAFT)
  criteria      Json
  instructions  String?
  changeNote    String?
  createdBy     String?
  publishedAt   DateTime?
  createdAt     DateTime                        @default(now())
  updatedAt     DateTime                        @updatedAt

  template          EvaluationTemplate               @relation(fields: [templateId], references: [id], onDelete: Restrict)
  assignments       JobProfileEvaluationAssignment[]
  resumeEvaluations ResumeEvaluationResult[]
  evaluationRuns    ResumeEvaluationRun[]

  @@unique([templateId, versionNumber])
  @@index([templateId, status])
  @@index([publishedAt])
  @@index([createdAt])
}

model JobProfileEvaluationAssignment {
  id                String    @id @default(cuid())
  jobProfileId      String
  templateVersionId String
  assignedBy        String?
  assignedAt        DateTime  @default(now())
  endedAt           DateTime?

  jobProfile      JobProfile                @relation(fields: [jobProfileId], references: [id], onDelete: Restrict)
  templateVersion EvaluationTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)

  @@index([jobProfileId])
  @@index([templateVersionId])
  @@index([endedAt])
  @@index([assignedAt])
}

model CandidateInsight {
  id                            String    @id @default(uuid())
  workflowId                    String
  jobProfileId                  String
  resumeId                      String    @unique
  candidateSource               String?
  notes                         String?
  summary                       Json
  insights                      Json
  strengths                     String[]
  potentialRisks                String[]
  missingInformation            String[]
  suggestedPhoneScreenQuestions String[]
  suggestedInterviewQuestions   String[]
  suggestedNextActions          String[]
  evidence                      Json
  aiProvider                    String
  aiModel                       String
  promptFile                    String
  promptVersion                 String
  generationTimeMs              Int?
  jobProfileVersion             String
  resumeVersion                 String
  reviewedAt                    DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  jobProfile               JobProfile                @relation(fields: [jobProfileId], references: [id])
  resume                   CandidateResume           @relation(fields: [resumeId], references: [id])
  recruitTogetherWorkflows RecruitTogetherWorkflow[]

  @@index([workflowId])
  @@index([jobProfileId])
  @@index([createdAt])
}

model RecruitTogetherWorkflow {
  id                   String   @id @default(uuid())
  workflowId           String
  jobProfileId         String
  candidateInsightId   String
  phonePreparation     Json
  phoneNotes           Json
  interviewPreparation Json
  interviewNotes       Json
  recruiterSummary     Json
  aiProvider           String
  aiModel              String
  promptVersions       Json
  generationTimes      Json
  humanReview          Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  jobProfile       JobProfile       @relation(fields: [jobProfileId], references: [id])
  candidateInsight CandidateInsight @relation(fields: [candidateInsightId], references: [id])

  @@index([workflowId])
  @@index([jobProfileId])
  @@index([candidateInsightId])
  @@index([createdAt])
}

model DailyRecruitingWorkspace {
  id                     String   @id @default(uuid())
  workflowId             String
  date                   DateTime
  activitySnapshot       Json
  dailySummary           Json
  recruitingInsights     Json
  tomorrowPriorities     Json
  improvementSuggestions Json
  manualNotes            String?
  aiProvider             String
  aiModel                String
  promptVersions         Json
  generationTimes        Json
  humanReview            Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([workflowId])
  @@index([date])
  @@index([createdAt])
}

model RecruiterWorkspaceNote {
  id             String   @id @default(uuid())
  date           DateTime
  content        String
  category       String?
  source         String   @default("MANUAL")
  searchableText String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
  @@index([createdAt])
}

model RecruiterWorkspaceScheduleItem {
  id          String   @id @default(uuid())
  date        DateTime
  itemType    String
  title       String
  startTime   String?
  relatedName String?
  notes       String?
  completed   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([itemType])
  @@index([createdAt])
}

model RecruitmentTask {
  id                    String    @id @default(uuid())
  sourceKey             String    @unique
  sourceType            String
  category              String
  title                 String
  priority              String
  priorityReason        String
  reason                String
  evidence              String[]
  relatedWorkflow       String?
  relatedCandidate      String?
  relatedJob            String?
  dueTime               DateTime?
  confidence            String    @default("MEDIUM")
  recommendedNextAction String
  status                String    @default("TODO")
  quickStartHref        String?
  createdBy             String    @default("AI_RECRUITER")
  reviewedByRecruiter   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  audits RecruitmentTaskAudit[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([sourceType])
  @@index([dueTime])
  @@index([createdAt])
}

model RecruitmentTaskAudit {
  id           String   @id @default(uuid())
  taskId       String
  action       String
  actor        String
  beforeStatus String?
  afterStatus  String?
  beforeValue  Json?
  afterValue   Json?
  note         String?
  createdAt    DateTime @default(now())

  task RecruitmentTask @relation(fields: [taskId], references: [id])

  @@index([taskId])
  @@index([action])
  @@index([createdAt])
}

model ResumeEvaluationResult {
  id                String                  @id @default(cuid())
  resumeId          String
  resumeRevisionId  String?
  parsedSnapshotId  String?
  selectedRunId     String?
  reviewedRunId     String?
  jobProfileId      String
  templateVersionId String
  jobProfileVersion String
  status            ResumeEvaluationStatus  @default(DRAFT)
  revision          Int                     @default(0)
  criterionResults  Json
  overallNote       String?
  evaluatedBy       String?
  reviewerDecision  ResumeReviewerDecision?
  reviewerNotes     String?
  reviewedAt        DateTime?
  reviewedBy        String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  resume          CandidateResume           @relation(fields: [resumeId], references: [id], onDelete: Restrict)
  resumeRevision  ResumeRevision?           @relation("EvaluationResumeRevision", fields: [resumeRevisionId], references: [id], onDelete: SetNull)
  parsedSnapshot  ParsedSnapshot?           @relation("EvaluationParsedSnapshot", fields: [parsedSnapshotId], references: [id], onDelete: SetNull)
  selectedRun     ResumeEvaluationRun?      @relation("SelectedEvaluationRun", fields: [selectedRunId], references: [id], onDelete: SetNull)
  reviewedRun     ResumeEvaluationRun?      @relation("ReviewedEvaluationRun", fields: [reviewedRunId], references: [id], onDelete: SetNull)
  jobProfile      JobProfile                @relation(fields: [jobProfileId], references: [id], onDelete: Restrict)
  templateVersion EvaluationTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  events          ResumeEvaluationEvent[]
  runs            ResumeEvaluationRun[]     @relation("EvaluationRuns")

  @@unique([resumeId, jobProfileId, templateVersionId, jobProfileVersion], name: "resumeEvaluationContext", map: "ResumeEvaluationResult_context_key")
  @@index([resumeId])
  @@index([resumeRevisionId])
  @@index([parsedSnapshotId])
  @@index([selectedRunId])
  @@index([reviewedRunId])
  @@index([jobProfileId])
  @@index([templateVersionId])
  @@index([status])
  @@index([evaluatedBy])
  @@index([updatedAt])
  @@index([createdAt])
}

model ResumeEvaluationRun {
  id                       String                    @id @default(cuid())
  evaluationId             String
  resumeId                 String
  resumeRevisionId         String
  parsedSnapshotId         String
  jobProfileId             String
  templateVersionId        String
  jobProfileVersion        String
  runType                  ResumeEvaluationRunType
  status                   ResumeEvaluationRunStatus
  score                    Int?
  rating                   String?
  summary                  String?
  strengthsJson            Json?
  weaknessesJson           Json?
  riskFlagsJson            Json?
  evidenceJson             Json?
  phoneScreenQuestionsJson Json?
  interviewQuestionsJson   Json?
  modelProvider            String?
  modelName                String?
  promptVersion            String?
  inputHash                String?
  outputHash               String?
  rawOutputJson            Json?
  parsedOutputJson         Json?
  errorCode                String?
  errorMessage             String?
  latencyMs                Int?
  createdAt                DateTime                  @default(now())
  completedAt              DateTime?

  evaluation            ResumeEvaluationResult    @relation("EvaluationRuns", fields: [evaluationId], references: [id], onDelete: Restrict)
  resume                CandidateResume           @relation(fields: [resumeId], references: [id], onDelete: Restrict)
  resumeRevision        ResumeRevision            @relation(fields: [resumeRevisionId], references: [id], onDelete: Restrict)
  parsedSnapshot        ParsedSnapshot            @relation(fields: [parsedSnapshotId], references: [id], onDelete: Restrict)
  jobProfile            JobProfile                @relation(fields: [jobProfileId], references: [id], onDelete: Restrict)
  templateVersion       EvaluationTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  selectedByEvaluations ResumeEvaluationResult[]  @relation("SelectedEvaluationRun")
  reviewedByEvaluations ResumeEvaluationResult[]  @relation("ReviewedEvaluationRun")

  @@index([evaluationId])
  @@index([resumeId])
  @@index([resumeRevisionId])
  @@index([parsedSnapshotId])
  @@index([jobProfileId])
  @@index([templateVersionId])
  @@index([status])
  @@index([runType])
  @@index([createdAt])
  @@index([evaluationId, status, createdAt])
}

model ResumeEvaluationEvent {
  id            String                    @id @default(cuid())
  evaluationId  String
  eventType     ResumeEvaluationEventType
  actor         String?
  changedFields String[]                  @default([])
  note          String?
  createdAt     DateTime                  @default(now())

  evaluation ResumeEvaluationResult @relation(fields: [evaluationId], references: [id], onDelete: Restrict)

  @@index([evaluationId, createdAt])
  @@index([eventType])
}
